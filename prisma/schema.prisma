generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          Int       @id @default(autoincrement())
  name        String
  key         String?   @unique
  description String?
  color       String    @default("#6366f1")
  status      String    @default("active")
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  tasks       Task[]
  epics       Epic[]
}

model Epic {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  status      String    @default("open")
  color       String    @default("#818cf8")
  projectId   Int?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tasks       Task[]
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
}

model Sprint {
  id          Int                @id @default(autoincrement())
  name        String
  startDate   DateTime?
  endDate     DateTime?
  status      String             @default("planning")
  order       Int                @default(0)
  closedAt    DateTime?
  createdAt   DateTime           @default(now())
  tasks       Task[]
  taskRecords SprintTaskRecord[]
}

model SprintTaskRecord {
  id                Int      @id @default(autoincrement())
  sprintId          Int
  sprint            Sprint   @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  taskId            Int
  taskTitle         String
  wasDone           Boolean
  movedToSprintId   Int?
  movedToSprintName String?
  createdAt         DateTime @default(now())
}

model Task {
  id          Int               @id @default(autoincrement())
  title       String
  description String?
  status      String            @default("open")
  done        Boolean           @default(false)
  priority    String            @default("medium")
  startDate   DateTime?
  endDate     DateTime?
  dueDate     DateTime?
  sprintId    Int?
  sprint      Sprint?           @relation(fields: [sprintId], references: [id])
  projectId   Int?
  project     Project?          @relation(fields: [projectId], references: [id])
  taskNumber  Int?
  order       Int               @default(0)
  createdAt   DateTime          @default(now())
  comments    Comment[]
  activities  TaskActivity[]
  attachments TaskAttachment[]
  epicId      Int?
  epic        Epic?             @relation(fields: [epicId], references: [id], onDelete: SetNull)
  parentId    Int?
  parent      Task?             @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks    Task[]            @relation("Subtasks")
}

model TaskAttachment {
  id        Int      @id @default(autoincrement())
  taskId    Int
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  filename  String
  filepath  String
  mimetype  String
  size      Int
  createdAt DateTime @default(now())
}

model TaskActivity {
  id        Int      @id @default(autoincrement())
  taskId    Int
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  field     String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())
}

model Comment {
  id        Int      @id @default(autoincrement())
  body      String
  taskId    Int
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
